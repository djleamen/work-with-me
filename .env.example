OPENAI_API_KEY=your_openai_api_key_here

# Optional — defaults to gpt-5.5 (current flagship; vision-capable).
# Set these to the strongest models your account can access.
# Cheaper/faster alternatives: gpt-5.4, gpt-5.4-mini, or gpt-4.1.
OPENAI_MODEL=gpt-5.5
OPENAI_VISION_MODEL=gpt-5.5
# Reasoning effort for GPT-5 / o-series models: none | low | medium | high
# Lower = snappier for interactive drawing. Ignored by gpt-4.x models.
OPENAI_REASONING_EFFORT=low
AI_TEMPERATURE=0.7
